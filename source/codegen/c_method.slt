module c_method;

use emitter;
use type_registry;
use registry_lookup;
use slate;
use c_call;

string build_method_str(string target_str, string method, list(string) arg_strs, string target_type, Registry reg) {
    if method == "len" {
        if target_type == "string" { return "(" + target_str + ")->length"; }
        return "slate_len(" + target_str + ")";
    }
    if method == "add" {
        return "slate_add(" + target_str + ", " + build_args_str(arg_strs, 0) + ")";
    }
    if method == "has" {
        return "slate_has(" + target_str + ", " + arg_strs.get(0) + ")";
    }
    if method == "keys"   { return "slate_keys(" + target_str + ")"; }
    if method == "values" { return "slate_values(" + target_str + ")"; }
    if method == "contains" {
        return "slate_contains(" + target_str + "->data, " + arg_strs.get(0) + "->data)";
    }
    if method == "split" {
        return "slate_split(" + target_str + "->data, " + arg_strs.get(0) + "->data)";
    }
    if method == "replace" {
        return "slate_cstr(slate_replace(" + target_str + "->data, " + arg_strs.get(0) + "->data, " + arg_strs.get(1) + "->data))";
    }
    if method == "starts_with" {
        return "slate_starts_with(" + target_str + "->data, " + arg_strs.get(0) + "->data)";
    }
    if method == "ends_with" {
        return "slate_ends_with(" + target_str + "->data, " + arg_strs.get(0) + "->data)";
    }
    if method == "trim"    { return "slate_cstr(slate_trim(" + target_str + "->data))"; }
    if method == "upper"   { return "slate_cstr(slate_str_upper(" + target_str + "->data))"; }
    if method == "lower"   { return "slate_cstr(slate_str_lower(" + target_str + "->data))"; }
    if method == "reverse" { return "slate_cstr(slate_str_reverse(" + target_str + "->data))"; }
    if method == "chars"   { return "slate_str_chars(" + target_str + "->data)"; }
    if method == "repeat" {
        return "slate_cstr(slate_str_repeat(" + target_str + "->data, " + build_args_str(arg_strs, 0) + "))";
    }
    if method == "first" { return "slate_list_first(" + target_str + ")"; }
    if method == "last"  { return "slate_list_last(" + target_str + ")"; }
    if method == "remove" {
        return "slate_list_remove(" + target_str + ", " + build_args_str(arg_strs, 0) + ")";
    }
    if method == "sort"  { return "slate_list_sort(" + target_str + ")"; }
    if method == "merge" {
        return "slate_list_merge(" + target_str + ", " + build_args_str(arg_strs, 0) + ")";
    }
    if method == "hash" { return "slate_cstr(slate_int_to_str(slate_hash(" + target_str + "->data)))"; }
    if method == "int"    { return "slate_to_int(" + target_str + "->data)"; }
    if method == "float"  { return "slate_to_float(" + target_str + "->data)"; }
    if method == "string" { return "slate_cstr(slate_to_string(" + target_str + "->data))"; }
    if method == "read"   { return "slate_cstr(slate_file_read(" + target_str + "->data))"; }
    if method == "write" {
        return "slate_file_write(" + target_str + "->data, " + arg_strs.get(0) + "->data)";
    }
    if method == "append" {
        return "slate_file_append(" + target_str + "->data, " + arg_strs.get(0) + "->data)";
    }
    if method == "list" { return "slate_file_list(" + target_str + "->data)"; }
    if method == "exists" {
        if target_type == "string" { return "slate_file_exists(" + target_str + "->data)"; }
        return "(" + target_str + " != NULL)";
    }
    if method == "or" {
        return "(" + target_str + " != NULL ? " + target_str + " : " + build_args_str(arg_strs, 0) + ")";
    }
    return target_str + "->" + method + "(" + build_args_str(arg_strs, 0) + ")";
}
